{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=CadenceComponentLibrary;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "FileStorage": {
    "AppDataRoot": "storage/app-data",
    "LibraryRoot": "library",
    "LogRoot": "storage/logs"
  },
  "Database": {
    "ApplySchemaChangesOnStartup": false
  },
  "CadenceAutomation": {
    "JobRoot": "storage/jobs",
    "CaptureQueuePath": "storage/jobs/capture",
    "AllegroQueuePath": "storage/jobs/allegro",
    "LibraryRoot": "library/Cadence"
  },
  "AiExtraction": {
    "Mode": "Stub",
    "CodexCli": {
      "Enabled": false,
      "Command": "codex",
      "Model": "",
      "Profile": "",
      "Sandbox": "read-only",
      "Ephemeral": true,
      "TimeoutSeconds": 180,
      "WorkingDirectory": ""
    },
    "OpenAI": {
      "Enabled": false,
      "BaseUrl": "https://api.openai.com/v1",
      "Model": "gpt-4.1-mini",
      "ApiKey": ""
    }
  },
  "ExternalImports": {
    "EasyEdaApiKey": "",
    "StorageRoot": "App_Data/ExternalImports",
    "EasyEdaNlbn": {
      "Enabled": true,
      "BaseUrl": "https://easyeda.com",
      "ComponentVersion": "6.4.19.5",
      "ModulesBaseUrl": "https://modules.easyeda.com",
      "StepPathPrefix": "qAxj6KHrDKw4blvCG8QJPs7Y",
      "DownloadStepByDefault": false,
      "DownloadObjByDefault": false,
      "GeneratePreviewByDefault": true,
      "MaxParallelImports": 4,
      "RequestDelayMs": 250
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}

