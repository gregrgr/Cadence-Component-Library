{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=CadenceComponentLibrary;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "FileStorage": {
    "AppDataRoot": "storage/app-data",
    "LibraryRoot": "library",
    "LogRoot": "storage/logs"
  },
  "Database": {
    "ApplySchemaChangesOnStartup": false
