@model CadenceComponentLibraryAdmin.Domain.Entities.LibraryRelease

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h4 mb-1">@Model.ReleaseName</h1>
        <div class="text-muted">Release snapshot details</div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</div>

<div class="page-card card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Release Date</dt>
            <dd class="col-sm-9">@Model.ReleaseDate.ToString("yyyy-MM-dd HH:mm")</dd>
            <dt class="col-sm-3">Released By</dt>
            <dd class="col-sm-9">@Model.ReleasedBy</dd>
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9"><partial name="~/Views/Shared/_StatusBadge.cshtml" model="@Model.Status.ToString()" /></dd>
            <dt class="col-sm-3">Part Count</dt>
            <dd class="col-sm-9">@Model.PartCount</dd>
            <dt class="col-sm-3">Footprint Count</dt>
            <dd class="col-sm-9">@Model.FootprintCount</dd>
            <dt class="col-sm-3">Symbol Count</dt>
            <dd class="col-sm-9">@Model.SymbolCount</dd>
            <dt class="col-sm-3">Release Note</dt>
            <dd class="col-sm-9">@Model.ReleaseNote</dd>
        </dl>
    </div>
</div>
