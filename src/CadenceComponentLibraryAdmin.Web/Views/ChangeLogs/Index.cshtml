@model CadenceComponentLibraryAdmin.Web.Models.PagedResult<CadenceComponentLibraryAdmin.Domain.Entities.PartChangeLog>
@{
    var query = (CadenceComponentLibraryAdmin.Application.DTOs.ChangeLogQuery)ViewBag.Query;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h4 mb-1">Change Logs</h1>
        <div class="text-muted">Review part history and export audit records.</div>
    </div>
    <a asp-action="Export"
       asp-route-companyPn="@query.CompanyPN"
       asp-route-changeType="@query.ChangeType"
       asp-route-changedFrom="@query.ChangedFrom"
       asp-route-changedTo="@query.ChangedTo"
       class="btn btn-outline-secondary">Export CSV</a>
</div>

<div class="page-card card mb-3">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Company Part Number</label>
                <input name="companyPn" value="@query.CompanyPN" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Change Type</label>
                <select name="changeType" asp-items="Html.GetEnumSelectList<CadenceComponentLibraryAdmin.Domain.Enums.ChangeType>()" class="form-select">
                    <option value="">All</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Changed From</label>
                <input name="changedFrom" type="date" value="@query.ChangedFrom?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Changed To</label>
                <input name="changedTo" type="date" value="@query.ChangedTo?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-2 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="page-card card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Company Part Number</th>
                    <th>Change Type</th>
                    <th>Old Value</th>
                    <th>New Value</th>
                    <th>Reason</th>
                    <th>Changed By</th>
                    <th>Changed At</th>
                    <th>Release Name</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td class="fw-semibold">@item.CompanyPN</td>
                    <td>@item.ChangeType</td>
                    <td>@item.OldValue</td>
                    <td>@item.NewValue</td>
                    <td>@item.Reason</td>
                    <td>@item.ChangedBy</td>
                    <td>@item.ChangedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@item.ReleaseName</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
<partial name="~/Views/Shared/_Pagination.cshtml" model='new CadenceComponentLibraryAdmin.Web.Models.PagedResult<object> { Items = Array.Empty<object>(), Page = Model.Page, PageSize = Model.PageSize, TotalCount = Model.TotalCount }' />
