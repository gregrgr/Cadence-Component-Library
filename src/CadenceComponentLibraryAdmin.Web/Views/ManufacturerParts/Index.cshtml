@model CadenceComponentLibraryAdmin.Web.Models.PagedResult<CadenceComponentLibraryAdmin.Domain.Entities.ManufacturerPart>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h4 mb-1">Manufacturer Parts</h1>
        <div class="text-muted">Manage manufacturer part numbers and approved sources.</div>
    </div>
    <a asp-action="Create" class="btn btn-primary">New Manufacturer Part</a>
</div>

<div class="page-card card mb-3">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-5">
                <label class="form-label">Search</label>
                <input name="search" value="@ViewBag.Search" class="form-control" placeholder="Manufacturer / Manufacturer Part Number" />
            </div>
            <div class="col-md-5">
                <label class="form-label">Company Part Number</label>
                <input name="companyPn" value="@ViewBag.CompanyPN" class="form-control" />
            </div>
            <div class="col-md-2 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="page-card card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Company Part Number</th>
                    <th>Manufacturer</th>
                    <th>Manufacturer Part Number</th>
                    <th>Lifecycle</th>
                    <th>Approved</th>
                    <th>Preferred</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.CompanyPN</td>
                    <td>@item.Manufacturer</td>
                    <td class="fw-semibold">@item.ManufacturerPN</td>
                    <td><partial name="~/Views/Shared/_StatusBadge.cshtml" model="@item.LifecycleStatus.ToString()" /></td>
                    <td>@(item.IsApproved ? "Yes" : "No")</td>
                    <td>@(item.IsPreferred ? "Yes" : "No")</td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
<partial name="~/Views/Shared/_Pagination.cshtml" model='new CadenceComponentLibraryAdmin.Web.Models.PagedResult<object> { Items = Array.Empty<object>(), Page = Model.Page, PageSize = Model.PageSize, TotalCount = Model.TotalCount }' />
