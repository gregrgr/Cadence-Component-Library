@model CadenceComponentLibraryAdmin.Domain.Entities.SymbolFamily

<div class="page-card card">
    <div class="card-body">
        <h1 class="h4 mb-3">Edit Symbol Family</h1>
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <partial name="_Form" model="Model" />
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Back</a>
            </div>
        </form>
    </div>
</div>
