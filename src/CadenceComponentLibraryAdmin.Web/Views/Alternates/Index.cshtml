@model CadenceComponentLibraryAdmin.Web.Models.PagedResult<CadenceComponentLibraryAdmin.Domain.Entities.PartAlternate>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h4 mb-1">Alternates</h1>
        <div class="text-muted">Manage approved and candidate substitute relations.</div>
    </div>
    <a asp-action="Create" class="btn btn-primary">New Alternate</a>
</div>

<div class="page-card card mb-3">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Company Part Number</label>
                <input name="companyPn" value="@ViewBag.CompanyPN" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Alternate Level</label>
                <select name="altLevel" asp-items="Html.GetEnumSelectList<CadenceComponentLibraryAdmin.Domain.Enums.AlternateLevel>()" class="form-select">
                    <option value="">All</option>
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="page-card card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Source</th>
                    <th>Target</th>
                    <th>Level</th>
                    <th>Same Footprint</th>
                    <th>Approved</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td class="fw-semibold">@item.SourceCompanyPN</td>
                    <td>@item.TargetCompanyPN</td>
                    <td>@item.AltLevel</td>
                    <td>@(item.SameFootprintYN ? "Yes" : "No")</td>
                    <td>@(item.ApprovedAt.HasValue ? item.ApprovedAt.Value.ToString("yyyy-MM-dd") : "Pending")</td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        @if (!item.ApprovedAt.HasValue)
                        {
                            <form asp-action="Approve" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Approve this alternate relation?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-success">Approve</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
<partial name="~/Views/Shared/_Pagination.cshtml" model='new CadenceComponentLibraryAdmin.Web.Models.PagedResult<object> { Items = Array.Empty<object>(), Page = Model.Page, PageSize = Model.PageSize, TotalCount = Model.TotalCount }' />
