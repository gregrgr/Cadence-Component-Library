@model CadenceComponentLibraryAdmin.Web.Models.AlternateListItemViewModel

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h4 mb-1">@Model.Alternate.SourceCompanyPN -> @Model.Alternate.TargetCompanyPN</h1>
        <div class="text-muted">Alternate relation details</div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Alternate.Id" class="btn btn-primary">Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="page-card card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Source Description</dt>
            <dd class="col-sm-9">@(Model.SourceDescription ?? "-")</dd>
            <dt class="col-sm-3">Target Description</dt>
            <dd class="col-sm-9">@(Model.TargetDescription ?? "-")</dd>
            <dt class="col-sm-3">Alternate Level</dt>
            <dd class="col-sm-9">@Model.Alternate.AltLevel</dd>
            <dt class="col-sm-3">Same Footprint</dt>
            <dd class="col-sm-9">@(Model.Alternate.SameFootprintYN ? "Yes" : "No")</dd>
            <dt class="col-sm-3">Same Symbol</dt>
            <dd class="col-sm-9">@(Model.Alternate.SameSymbolYN ? "Yes" : "No")</dd>
            <dt class="col-sm-3">Need EE Review</dt>
            <dd class="col-sm-9">@(Model.Alternate.NeedEEReviewYN ? "Yes" : "No")</dd>
            <dt class="col-sm-3">Need Layout Review</dt>
            <dd class="col-sm-9">@(Model.Alternate.NeedLayoutReviewYN ? "Yes" : "No")</dd>
            <dt class="col-sm-3">Approved By</dt>
            <dd class="col-sm-9">@(Model.Alternate.ApprovedBy ?? "-")</dd>
            <dt class="col-sm-3">Approved At</dt>
            <dd class="col-sm-9">@Model.Alternate.ApprovedAt</dd>
            <dt class="col-sm-3">Notes</dt>
            <dd class="col-sm-9">@Model.Alternate.Notes</dd>
        </dl>
    </div>
</div>
