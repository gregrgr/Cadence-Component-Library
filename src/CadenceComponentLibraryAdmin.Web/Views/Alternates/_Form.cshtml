@model CadenceComponentLibraryAdmin.Domain.Entities.PartAlternate

<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="SourceCompanyPN" class="form-label"></label>
        <select asp-for="SourceCompanyPN" asp-items="ViewBag.CompanyParts" class="form-select"></select>
    </div>
    <div class="col-md-6">
        <label asp-for="TargetCompanyPN" class="form-label"></label>
        <select asp-for="TargetCompanyPN" asp-items="ViewBag.CompanyParts" class="form-select"></select>
    </div>
    <div class="col-md-3">
        <label asp-for="AltLevel" class="form-label"></label>
        <select asp-for="AltLevel" asp-items="Html.GetEnumSelectList<CadenceComponentLibraryAdmin.Domain.Enums.AlternateLevel>()" class="form-select"></select>
    </div>
    <div class="col-12">
        <div class="alert alert-info mb-0">
            Compatibility flags are calculated automatically from the selected source and target company parts when you save.
        </div>
    </div>
    <div class="col-md-3">
        <label class="form-label" asp-for="SameFootprintYN"></label>
        <input type="hidden" asp-for="SameFootprintYN" />
        <input class="form-control" value="@(Model.SameFootprintYN ? "Yes" : "No")" readonly />
    </div>
    <div class="col-md-3">
        <label class="form-label" asp-for="SameSymbolYN"></label>
        <input type="hidden" asp-for="SameSymbolYN" />
        <input class="form-control" value="@(Model.SameSymbolYN ? "Yes" : "No")" readonly />
    </div>
    <div class="col-md-3">
        <label class="form-label" asp-for="NeedEEReviewYN"></label>
        <input type="hidden" asp-for="NeedEEReviewYN" />
        <input class="form-control" value="@(Model.NeedEEReviewYN ? "Yes" : "No")" readonly />
    </div>
    <div class="col-md-3">
        <label class="form-label" asp-for="NeedLayoutReviewYN"></label>
        <input type="hidden" asp-for="NeedLayoutReviewYN" />
        <input class="form-control" value="@(Model.NeedLayoutReviewYN ? "Yes" : "No")" readonly />
    </div>
    <div class="col-12">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
    </div>
</div>
