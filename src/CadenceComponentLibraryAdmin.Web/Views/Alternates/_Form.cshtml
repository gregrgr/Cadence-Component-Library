@model CadenceComponentLibraryAdmin.Domain.Entities.PartAlternate

<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="SourceCompanyPN" class="form-label"></label>
        <select asp-for="SourceCompanyPN" asp-items="ViewBag.CompanyParts" class="form-select"></select>
    </div>
    <div class="col-md-6">
        <label asp-for="TargetCompanyPN" class="form-label"></label>
        <select asp-for="TargetCompanyPN" asp-items="ViewBag.CompanyParts" class="form-select"></select>
    </div>
    <div class="col-md-3">
        <label asp-for="AltLevel" class="form-label"></label>
        <select asp-for="AltLevel" asp-items="Html.GetEnumSelectList<CadenceComponentLibraryAdmin.Domain.Enums.AlternateLevel>()" class="form-select"></select>
    </div>
    <div class="col-12 d-flex flex-wrap gap-4">
        <div class="form-check">
            <input asp-for="SameFootprintYN" class="form-check-input" />
            <label asp-for="SameFootprintYN" class="form-check-label"></label>
        </div>
        <div class="form-check">
            <input asp-for="SameSymbolYN" class="form-check-input" />
            <label asp-for="SameSymbolYN" class="form-check-label"></label>
        </div>
        <div class="form-check">
            <input asp-for="NeedEEReviewYN" class="form-check-input" />
            <label asp-for="NeedEEReviewYN" class="form-check-label"></label>
        </div>
        <div class="form-check">
            <input asp-for="NeedLayoutReviewYN" class="form-check-input" />
            <label asp-for="NeedLayoutReviewYN" class="form-check-label"></label>
        </div>
    </div>
    <div class="col-12">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
    </div>
</div>
