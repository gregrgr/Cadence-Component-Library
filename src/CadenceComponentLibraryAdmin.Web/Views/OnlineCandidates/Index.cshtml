@model CadenceComponentLibraryAdmin.Web.Models.PagedResult<CadenceComponentLibraryAdmin.Domain.Entities.OnlineCandidate>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h4 mb-1">Online Candidates</h1>
        <div class="text-muted">Collect web-sourced candidate parts before internal approval.</div>
    </div>
    <a asp-action="Create" class="btn btn-primary">New Online Candidate</a>
</div>

<div class="page-card card mb-3">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-5">
                <label class="form-label">Search</label>
                <input name="search" value="@ViewBag.Search" class="form-control" placeholder="Manufacturer / Manufacturer Part Number" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Source Provider</label>
                <input name="sourceProvider" value="@ViewBag.SourceProvider" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Status</label>
                <select name="status" asp-items="Html.GetEnumSelectList<CadenceComponentLibraryAdmin.Domain.Enums.CandidateStatus>()" class="form-select">
                    <option value="">All</option>
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="page-card card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Manufacturer</th>
                    <th>Manufacturer Part Number</th>
                    <th>Source</th>
                    <th>Status</th>
                    <th>Lifecycle</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Manufacturer</td>
                    <td class="fw-semibold">@item.ManufacturerPN</td>
                    <td>@item.SourceProvider</td>
                    <td><partial name="~/Views/Shared/_StatusBadge.cshtml" model="@item.CandidateStatus.ToString()" /></td>
                    <td><partial name="~/Views/Shared/_StatusBadge.cshtml" model="@item.LifecycleStatus.ToString()" /></td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
<partial name="~/Views/Shared/_Pagination.cshtml" model='new CadenceComponentLibraryAdmin.Web.Models.PagedResult<object> { Items = Array.Empty<object>(), Page = Model.Page, PageSize = Model.PageSize, TotalCount = Model.TotalCount }' />
