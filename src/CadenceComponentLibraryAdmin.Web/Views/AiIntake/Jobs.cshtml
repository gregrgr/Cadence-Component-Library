@model CadenceComponentLibraryAdmin.Web.Models.AiIntakeJobsViewModel

@{
    ViewData["Title"] = "AI Intake Jobs";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h4 mb-1">Cadence Build Jobs</h1>
        <p class="text-muted mb-0">Queued and completed symbol/footprint jobs for extraction #@Model.Extraction.Id.</p>
    </div>
    <a asp-action="Details" asp-route-id="@Model.Extraction.Id" class="btn btn-outline-secondary">Back</a>
</div>

<div class="card page-card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Tool</th>
                    <th>Created</th>
                    <th>Artifacts</th>
                    <th>Error</th>
                </tr>
                </thead>
                <tbody>
                @if (Model.Jobs.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-muted">No jobs queued yet.</td>
                    </tr>
                }
                else
                {
                    @foreach (var job in Model.Jobs)
                    {
                        <tr>
                            <td class="font-monospace">@job.Id</td>
                            <td>@job.JobType</td>
                            <td><span class="badge text-bg-light border">@job.Status</span></td>
                            <td>@job.ToolName</td>
                            <td>@job.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                @if (job.Artifacts.Count == 0)
                                {
                                    <span class="text-muted">None</span>
                                }
                                else
                                {
                                    <ul class="mb-0 ps-3">
                                        @foreach (var artifact in job.Artifacts)
                                        {
                                            <li>@artifact.ArtifactType: @artifact.FilePath</li>
                                        }
                                    </ul>
                                }
                            </td>
                            <td class="text-danger small">@job.ErrorMessage</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
