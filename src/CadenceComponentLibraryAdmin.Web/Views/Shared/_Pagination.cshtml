@model CadenceComponentLibraryAdmin.Web.Models.PagedResult<object>

@if (Model.TotalPages > 1)
{
    var routeValues = new Dictionary<string, string?>();
    foreach (var key in ViewContext.HttpContext.Request.Query.Keys)
    {
        if (!string.Equals(key, "page", StringComparison.OrdinalIgnoreCase))
        {
            routeValues[key] = ViewContext.HttpContext.Request.Query[key].ToString();
        }
    }

    <nav aria-label="Pagination" class="mt-3">
        <ul class="pagination mb-0">
            <li class="page-item @(Model.HasPreviousPage ? string.Empty : "disabled")">
                <a class="page-link" asp-route-page="@(Model.Page - 1)" asp-all-route-data="routeValues">Previous</a>
            </li>
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : string.Empty)">
                    <a class="page-link" asp-route-page="@i" asp-all-route-data="routeValues">@i</a>
                </li>
            }
            <li class="page-item @(Model.HasNextPage ? string.Empty : "disabled")">
                <a class="page-link" asp-route-page="@(Model.Page + 1)" asp-all-route-data="routeValues">Next</a>
            </li>
        </ul>
    </nav>
}
