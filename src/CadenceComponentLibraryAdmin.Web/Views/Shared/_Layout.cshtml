<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cadence Component Library Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f5f7fb;
        }

        .app-shell {
            min-height: 100vh;
        }

        .sidebar {
            width: 260px;
            background: #18212f;
        }

        .sidebar .nav-link {
            color: #c8d1dd;
            border-radius: .5rem;
            margin-bottom: .25rem;
        }

        .sidebar .nav-link:hover,
        .sidebar .nav-link.active {
            color: #fff;
            background: rgba(255, 255, 255, 0.08);
        }

        .content-header {
            border-bottom: 1px solid #e6e9ef;
            background: #fff;
        }

        .page-card {
            border: 0;
            box-shadow: 0 0.25rem 1rem rgba(24, 33, 47, 0.06);
        }
    </style>
</head>
<body>
    <div class="d-flex app-shell">
        <aside class="sidebar text-white p-3 d-none d-lg-block">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-white">
                <div class="fs-5 fw-semibold mb-4">Cadence Component Library Admin</div>
            </a>

            <div class="text-uppercase small text-secondary mb-2">Navigation</div>
            <nav class="nav flex-column">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : string.Empty)" asp-controller="Home" asp-action="Index">Dashboard</a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "OnlineCandidates" ? "active" : string.Empty)" asp-controller="OnlineCandidates" asp-action="Index">Online Candidates</a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "CompanyParts" ? "active" : string.Empty)" asp-controller="CompanyParts" asp-action="Index">Company Parts</a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ManufacturerParts" ? "active" : string.Empty)" asp-controller="ManufacturerParts" asp-action="Index">Manufacturer Parts</a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "SymbolFamilies" ? "active" : string.Empty)" asp-controller="SymbolFamilies" asp-action="Index">Symbol Families</a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "PackageFamilies" ? "active" : string.Empty)" asp-controller="PackageFamilies" asp-action="Index">Package Families</a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "FootprintVariants" ? "active" : string.Empty)" asp-controller="FootprintVariants" asp-action="Index">Footprint Variants</a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Alternates" ? "active" : string.Empty)" asp-controller="Alternates" asp-action="Index">Alternates</a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ApprovalQueue" ? "active" : string.Empty)" asp-controller="ApprovalQueue" asp-action="Index">Approval Queue</a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "QualityReports" ? "active" : string.Empty)" asp-controller="QualityReports" asp-action="Index">Quality Reports</a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "LibraryReleases" ? "active" : string.Empty)" asp-controller="LibraryReleases" asp-action="Index">Library Releases</a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ChangeLogs" ? "active" : string.Empty)" asp-controller="ChangeLogs" asp-action="Index">Change Logs</a>
            </nav>
        </aside>

        <div class="flex-grow-1">
            <header class="content-header px-4 py-3 d-flex justify-content-between align-items-center">
                <div>
                    <div class="fw-semibold">@ViewContext.RouteData.Values["controller"]</div>
                    <div class="text-muted small">Personal-grade library administration for OrCAD Capture CIS and Allegro.</div>
                </div>
                <partial name="_LoginPartial" />
            </header>

            <main class="container-fluid py-4 px-4">
                <partial name="_FlashMessages" />
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
