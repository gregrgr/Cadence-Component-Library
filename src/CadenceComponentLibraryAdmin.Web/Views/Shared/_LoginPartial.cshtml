@using CadenceComponentLibraryAdmin.Infrastructure.Data
@using CadenceComponentLibraryAdmin.Web
@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Localization
@inject SignInManager<ApplicationUser> SignInManager
@inject IStringLocalizer<SharedResource> Localizer

<ul class="navbar-nav ms-auto">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <span class="nav-link">@User.Identity?.Name</span>
    </li>
    <li class="nav-item">
        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = string.Empty })" method="post">
            <button type="submit" class="btn btn-outline-secondary btn-sm">@Localizer["Logout"]</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="btn btn-outline-secondary btn-sm" asp-area="Identity" asp-page="/Account/Login">@Localizer["Login"]</a>
    </li>
}
</ul>
