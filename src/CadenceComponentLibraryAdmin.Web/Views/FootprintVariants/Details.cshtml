@model CadenceComponentLibraryAdmin.Domain.Entities.FootprintVariant

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h4 mb-1">@Model.FootprintName</h1>
        <div class="text-muted">@Model.PackageFamilyCode</div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Delete this footprint variant?');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger">Delete</button>
        </form>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="page-card card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Package Family</dt>
            <dd class="col-sm-9">@Model.PackageFamilyCode</dd>
            <dt class="col-sm-3">Variant Type</dt>
            <dd class="col-sm-9">@Model.VariantType</dd>
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9"><partial name="~/Views/Shared/_StatusBadge.cshtml" model="@Model.Status.ToString()" /></dd>
            <dt class="col-sm-3">PSM Path</dt>
            <dd class="col-sm-9"><code>@Model.PsmPath</code></dd>
            <dt class="col-sm-3">DRA Path</dt>
            <dd class="col-sm-9"><code>@Model.DraPath</code></dd>
            <dt class="col-sm-3">Padstack Set</dt>
            <dd class="col-sm-9">@Model.PadstackSet</dd>
            <dt class="col-sm-3">STEP Path</dt>
            <dd class="col-sm-9"><code>@Model.StepPath</code></dd>
        </dl>
    </div>
</div>
