@model CadenceComponentLibraryAdmin.Web.Models.PagedResult<CadenceComponentLibraryAdmin.Domain.Entities.CompanyPart>

@{
    var canMutateCompanyParts = User.IsInRole("Admin") || User.IsInRole("Librarian") || User.IsInRole("EEReviewer") || User.IsInRole("Purchasing");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h4 mb-1">Company Parts</h1>
        <div class="text-muted">Search and maintain internal part numbers.</div>
    </div>
    @if (canMutateCompanyParts)
    {
        <a asp-action="Create" class="btn btn-primary">New Company Part</a>
    }
</div>

<div class="page-card card mb-3">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Search</label>
                <input name="search" value="@ViewBag.Search" class="form-control" placeholder="CompanyPN / Description / Value / Class" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Approval</label>
                <select name="approvalStatus" asp-items="Html.GetEnumSelectList<CadenceComponentLibraryAdmin.Domain.Enums.ApprovalStatus>()" class="form-select">
                    <option value="">All</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Lifecycle</label>
                <select name="lifecycleStatus" asp-items="Html.GetEnumSelectList<CadenceComponentLibraryAdmin.Domain.Enums.LifecycleStatus>()" class="form-select">
                    <option value="">All</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Package Family</label>
                <input name="packageFamilyCode" value="@ViewBag.PackageFamilyCode" class="form-control" />
            </div>
            <div class="col-md-2 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="page-card card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Company Part Number</th>
                    <th>Description</th>
                    <th>Class</th>
                    <th>Symbol</th>
                    <th>Footprint</th>
                    <th>Status</th>
                    <th>Lifecycle</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td class="fw-semibold">@item.CompanyPN</td>
                    <td>@item.Description</td>
                    <td>@item.PartClass</td>
                    <td>@item.SymbolFamilyCode</td>
                    <td>@item.DefaultFootprintName</td>
                    <td><partial name="~/Views/Shared/_StatusBadge.cshtml" model="@item.ApprovalStatus.ToString()" /></td>
                    <td><partial name="~/Views/Shared/_StatusBadge.cshtml" model="@item.LifecycleStatus.ToString()" /></td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                        @if (canMutateCompanyParts)
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
<partial name="~/Views/Shared/_Pagination.cshtml" model='new CadenceComponentLibraryAdmin.Web.Models.PagedResult<object> { Items = Array.Empty<object>(), Page = Model.Page, PageSize = Model.PageSize, TotalCount = Model.TotalCount }' />
