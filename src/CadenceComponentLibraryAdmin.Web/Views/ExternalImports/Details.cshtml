@using System.Text.Json
@using CadenceComponentLibraryAdmin.Domain.Enums
@model CadenceComponentLibraryAdmin.Web.Models.ExternalImportDetailsViewModel

@functions {
    private string Pretty(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "No data";
        }

        try
        {
            using var document = JsonDocument.Parse(value);
            return JsonSerializer.Serialize(document.RootElement, new JsonSerializerOptions { WriteIndented = true });
        }
        catch (JsonException)
        {
            return value;
        }
    }

    private int CountShapes(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return 0;
        }

        try
        {
            using var document = JsonDocument.Parse(value);
            if (document.RootElement.ValueKind == JsonValueKind.Array)
            {
                return document.RootElement.GetArrayLength();
            }

            if (document.RootElement.ValueKind == JsonValueKind.String)
            {
                return document.RootElement.GetString()?
                    .Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                    .Length ?? 0;
            }
        }
        catch (JsonException)
        {
            return value.Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).Length;
        }

        return 0;
    }
}

@{
    ViewData["Title"] = "External Import Details";
    var item = Model.Import;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h4 mb-1">External Import Details</h1>
        <p class="text-muted mb-0">Staging-only EasyEDA/LCSC import. No APPROVED CompanyPart or Released FootprintVariant is created automatically from this page.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
        @if (User.IsInRole("Admin") || User.IsInRole("Librarian") || User.IsInRole("EEReviewer"))
        {
            <form asp-action="CreateCandidate" method="post" onsubmit="return confirm('Create an Online Candidate from this staged import?');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@item.Id" />
                <button type="submit" class="btn btn-primary" @(item.CandidateId.HasValue ? "disabled" : null)>Create Online Candidate</button>
            </form>
            <form asp-action="Reject" method="post" onsubmit="return confirm('Reject this external import?');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@item.Id" />
                <button type="submit" class="btn btn-outline-danger">Reject Import</button>
            </form>
        }
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card page-card mb-4">
            <div class="card-body">
                <h2 class="h5">Basic Info</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@item.Name</dd>
                    <dt class="col-sm-4">Source</dt>
                    <dd class="col-sm-8">@item.SourceName</dd>
                    <dt class="col-sm-4">LCSC ID</dt>
                    <dd class="col-sm-8">@item.LcscId</dd>
                    <dt class="col-sm-4">Manufacturer</dt>
                    <dd class="col-sm-8">@item.Manufacturer</dd>
                    <dt class="col-sm-4">Manufacturer PN Candidate</dt>
                    <dd class="col-sm-8">@item.ManufacturerPN</dd>
                    <dt class="col-sm-4">Package Name</dt>
                    <dd class="col-sm-8">@item.PackageName</dd>
                    <dt class="col-sm-4">JLC Part Class</dt>
                    <dd class="col-sm-8">@item.JlcPartClass</dd>
                    <dt class="col-sm-4">Description</dt>
                    <dd class="col-sm-8">@item.Description</dd>
                    <dt class="col-sm-4">Datasheet</dt>
                    <dd class="col-sm-8">@item.DatasheetUrl</dd>
                    <dt class="col-sm-4">Manual</dt>
                    <dd class="col-sm-8">@item.ManualUrl</dd>
                    <dt class="col-sm-4">Duplicate Warning</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(item.DuplicateWarning) ? "None" : item.DuplicateWarning)</dd>
                    <dt class="col-sm-4">Import Status</dt>
                    <dd class="col-sm-8"><span class="badge text-bg-light border">@item.ImportStatus</span></dd>
                    <dt class="col-sm-4">Candidate</dt>
                    <dd class="col-sm-8">@(item.CandidateId.HasValue ? $"OnlineCandidate #{item.CandidateId}" : "Not created")</dd>
                </dl>
            </div>
        </div>

        <div class="card page-card mb-4">
            <div class="card-body">
                <h2 class="h5">Shape Summary</h2>
                <div class="row">
                    <div class="col-md-6">
                        <div class="fw-semibold">Symbol</div>
                        <div class="small text-muted">Shape count: @CountShapes(item.SymbolShapeJson)</div>
                        <div class="small text-muted">BBox: @item.SymbolBBoxX / @item.SymbolBBoxY</div>
                    </div>
                    <div class="col-md-6">
                        <div class="fw-semibold">Footprint</div>
                        <div class="small text-muted">Shape count: @CountShapes(item.FootprintShapeJson)</div>
                        <div class="small text-muted">BBox: @item.FootprintBBoxX / @item.FootprintBBoxY</div>
                    </div>
                </div>
                <hr />
                <div class="row">
                    <div class="col-md-6">
                        <div class="fw-semibold">3D Model</div>
                        <div class="small text-muted">UUID: @item.Model3DUuid</div>
                        <div class="small text-muted">Title: @item.Model3DName</div>
                    </div>
                    <div class="col-md-6">
                        <div class="fw-semibold">Legacy Links</div>
                        <div class="small text-muted">Footprint name: @item.FootprintName</div>
                        <div class="small text-muted">STEP URL: @item.StepUrl</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card page-card">
            <div class="card-body">
                <h2 class="h5">Raw JSON</h2>
                <ul class="nav nav-tabs" id="rawJsonTabs" role="tablist">
                    <li class="nav-item" role="presentation"><button class="nav-link active" id="easyeda-raw-tab" data-bs-toggle="tab" data-bs-target="#easyeda-raw" type="button">EasyEDA raw response</button></li>
                    <li class="nav-item" role="presentation"><button class="nav-link" id="datastr-tab" data-bs-toggle="tab" data-bs-target="#datastr-json" type="button">dataStr</button></li>
                    <li class="nav-item" role="presentation"><button class="nav-link" id="package-tab" data-bs-toggle="tab" data-bs-target="#package-json" type="button">packageDetail</button></li>
                    <li class="nav-item" role="presentation"><button class="nav-link" id="cpara-tab" data-bs-toggle="tab" data-bs-target="#cpara-json" type="button">c_para</button></li>
                    <li class="nav-item" role="presentation"><button class="nav-link" id="lcsc-tab" data-bs-toggle="tab" data-bs-target="#lcsc-json" type="button">lcsc</button></li>
                </ul>
                <div class="tab-content border border-top-0 rounded-bottom p-3">
                    <div class="tab-pane fade show active" id="easyeda-raw"><pre class="mb-0 small">@Pretty(item.EasyEdaRawJson ?? item.FullRawJson)</pre></div>
                    <div class="tab-pane fade" id="datastr-json"><pre class="mb-0 small">@Pretty(item.EasyEdaDataStrRawJson)</pre></div>
                    <div class="tab-pane fade" id="package-json"><pre class="mb-0 small">@Pretty(item.EasyEdaPackageDetailRawJson)</pre></div>
                    <div class="tab-pane fade" id="cpara-json"><pre class="mb-0 small">@Pretty(item.EasyEdaCParaJson)</pre></div>
                    <div class="tab-pane fade" id="lcsc-json"><pre class="mb-0 small">@Pretty(item.EasyEdaLcscRawJson)</pre></div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card page-card mb-4">
            <div class="card-body">
                <h2 class="h5">Preview</h2>
                @if (item.FootprintPreviewAssetId.HasValue || item.FootprintRenderAssetId.HasValue)
                {
                    <img src="@Url.Action("Asset", new { id = item.FootprintPreviewAssetId ?? item.FootprintRenderAssetId })" alt="footprint preview" class="img-fluid rounded border mb-3" />
                }
                else
                {
                    <p class="text-muted">No preview generated.</p>
                }
            </div>
        </div>

        <div class="card page-card">
            <div class="card-body">
                <h2 class="h5">Linked Assets</h2>
                @if (Model.Assets.Count == 0)
                {
                    <p class="text-muted mb-0">No assets linked.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var asset in Model.Assets)
                        {
                            <li class="list-group-item px-0">
                                <div class="fw-semibold">@asset.AssetType</div>
                                <div class="small text-muted">@asset.OriginalFileName</div>
                                <div class="small text-muted">@asset.Url</div>
                                <div class="small text-muted">@asset.Sha256</div>
                                <a asp-action="Asset" asp-route-id="@asset.Id" class="small">Open asset</a>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
