@model CadenceComponentLibraryAdmin.Web.Models.AdminRolesIndexViewModel

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h4 mb-1">Roles</h1>
        <div class="text-muted">Admin-only management for seeded system roles and custom application roles.</div>
    </div>
    <a asp-action="Create" class="btn btn-primary">Create Role</a>
</div>

<div class="page-card card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Users</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var role in Model.Roles)
            {
                <tr>
                    <td class="fw-semibold">@role.Name</td>
                    <td>@(role.IsSystemRole ? "Seeded system role" : "Custom role")</td>
                    <td>@(role.Users.Count == 0 ? "-" : string.Join(", ", role.Users))</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@role.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        @if (!role.IsSystemRole)
                        {
                            <form asp-action="Delete" asp-route-id="@role.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this role?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
