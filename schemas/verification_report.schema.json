{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cadence-component-library.local/schemas/verification_report.schema.json",
  "title": "Verification Report",
  "type": "object",
  "required": [
    "overallStatus"
  ],
  "properties": {
    "overallStatus": {
      "type": "string",
      "enum": [
        "Pass",
        "Warning",
        "Fail"
      ]
    },
    "symbolChecks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "footprintChecks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
