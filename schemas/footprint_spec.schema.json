{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cadence-component-library.local/schemas/footprint_spec.schema.json",
  "title": "Footprint Spec",
  "type": "object",
  "properties": {
    "footprintName": {
      "type": "string"
    },
    "packageType": {
      "type": "string"
    },
    "pads": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "shape": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "name"
        ],
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
